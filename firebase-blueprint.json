{
  "entities": {
    "User": {
      "title": "User",
      "description": "App user with a simple PIN",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "Unique username"
        },
        "pin": {
          "type": "string",
          "description": "4-digit PIN"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user was created"
        }
      },
      "required": ["username", "pin"]
    }
  },
  "firestore": {
    "/users/{username}": {
      "schema": "User",
      "description": "Collection of users indexed by username"
    }
  }
}
